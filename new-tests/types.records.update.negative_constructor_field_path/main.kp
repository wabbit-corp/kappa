module main

-- Source issue: Idris2#628
-- Kappa analogue: constructor fields on an ordinary `data` constructor do not become record-update paths.
-- Spec: §5.5.5, §11.1.1
data Box : Type =
    Box {
        value : Int
    }

bad : Box -> Box
let bad (b : Box) : Box = b.{ value = 2 }

--! assertErrorCount 1
--! assertDiagnosticMatch record|update|constructor|field|Box|value
