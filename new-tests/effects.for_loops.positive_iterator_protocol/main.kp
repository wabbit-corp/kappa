module main

import std.prelude.(type Option, ctor Some, ctor None)

-- Source issues: KT-341, KT-566
-- Spec: §8.7.5, §12.2.1
data CountDown : Type =
    CountDown (remaining : Int)

instance Iterator CountDown =
    let Item = Int
    let next this =
        match this
          case CountDown remaining ->
            if remaining == 0 then
                None
            else
                Some (item = remaining, rest = CountDown (remaining - 1))

loopOverIterator : CountDown -> UIO Unit
let loopOverIterator xs =
    do
        for x in xs do
            pure ()
        pure ()

--! assertNoErrors
--! assertType loopOverIterator CountDown -> UIO Unit
