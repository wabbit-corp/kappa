module main

-- Source family: indexed impossible-remainder issue family
-- Spec: §7.5.1, §7.5.2A, §11.2
data Tag (a : Type) : Type =
    IsBool : Tag Bool
    IsInt : Tag Int

choose : Tag Bool -> Bool
let choose x =
    match x
      case IsBool -> True
      case impossible

--! assertNoErrors
--! assertType choose (Tag Bool) -> Bool
