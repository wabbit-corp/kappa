module main

-- Source issue: effekt#548
-- Spec: §8.1.8, §14.8.5, §17.3.1.7
let forward f = f

let leaked =
    block
        scoped effect Escape =
            escape : Unit -> Int

        let local () = Escape.escape ()
        forward local

--! assertErrorCount 1
--! assertDiagnosticMatch scoped|effect|escape|local
