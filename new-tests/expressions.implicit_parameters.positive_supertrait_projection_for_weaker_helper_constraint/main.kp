module main

trait Semigroup a =
    append : a -> a -> a

trait Semigroup a => Monoid a =
    neutral : a

trait Monoid a => VerifiedMonoid a =

repeatTwice : (@_ : Monoid Int) -> Int -> Int
let repeatTwice x =
    append x (append x neutral)

useVerified : (@_ : VerifiedMonoid Int) -> Int -> Int
let useVerified x =
    repeatTwice x

instance Semigroup Int =
    let append x y = x + y

instance Monoid Int =
    let neutral = 0

instance VerifiedMonoid Int =

result : Int
let result = useVerified 21

