module cases.e16_union_match.main

type IntOrString = (| Int | String |)

score : IntOrString -> Int
let score value =
    match value
    case (| n : Int |) -> n
    case (| _ : String |) -> 0

result : Int
let result =
    score (| 42 : Int |)


main : UIO Unit
let main = do
    let _ = result
    println "e16_union_match"

