module cases.e20_refutable_comprehension.main

sumList : List Int -> Int
let sumList xs decreases structural xs =
    match xs
    case Nil -> 0
    case h :: t -> h + sumList t

values : List Int
let values =
    [ for? Some x in [Some 1, None, Some 2, Some 39], yield x ]

result : Int
let result =
    sumList values


main : UIO Unit
let main = do
    let _ = result
    println "e20_refutable_comprehension"

--! assertType cases.e20_refutable_comprehension.main.result Int
--! assertType cases.e20_refutable_comprehension.main.main UIO Unit
