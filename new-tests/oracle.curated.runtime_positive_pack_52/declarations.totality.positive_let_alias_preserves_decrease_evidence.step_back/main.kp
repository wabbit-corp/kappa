module main

-- Source issues: Idris2#493, Idris2#300
-- Spec: §6.3.1, §6.4.2, §6.4.5
sizeViaAlias : List Int -> Int
let sizeViaAlias xs =
    match xs
      case Nil -> 0
      case _ :: tail ->
          let
              tail1 = tail
          in
              if True then 1 + sizeViaAlias tail1 else 0

baseResult : Int
let baseResult = sizeViaAlias (1 :: 2 :: 3 :: Nil)

step : Int -> Int
let step value = value + 1

back : Int -> Int
let back value = value - 1

result : Int
let result = back (step baseResult)

--! assertNoErrors
--! assertType result Int
--! assertExecute result 3
