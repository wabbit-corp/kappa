module main

-- Source issue: Idris2#403
-- Kappa analogue: branch-local splitting must preserve recursive decrease evidence.
-- Spec: §6.4.2, §6.4.5, §17.3.1.4
mergeCount : Bool -> List Int -> List Int -> Int
let mergeCount preferLeft xs ys =
    match xs
      case Nil ->
          match ys
            case Nil -> 0
            case _ :: ysTail -> 1 + mergeCount preferLeft Nil ysTail
      case x :: xsTail ->
          match ys
            case Nil -> 1 + mergeCount preferLeft xsTail Nil
            case y :: ysTail ->
                if preferLeft
                then 1 + mergeCount False xsTail (y :: ysTail)
                else 1 + mergeCount True (x :: xsTail) ysTail

baseResult : Int
let baseResult = mergeCount True (1 :: 2 :: Nil) (10 :: 11 :: Nil)

chooseResult : Bool -> Int -> Int -> Int
let chooseResult flag left right =
    if flag then left else right

result : Int
let result = chooseResult True baseResult 0

--! assertNoErrors
--! assertType result Int
--! assertExecute result 4
