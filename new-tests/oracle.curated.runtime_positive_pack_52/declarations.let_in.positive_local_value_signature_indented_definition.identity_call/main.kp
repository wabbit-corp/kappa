module main

-- Source issue: Idris2#31
-- Kappa analogue: a local signature plus indented local definition forms one block-scoped declaration sequence.
-- Spec: §3.4, §6.3.1
baseResult : Int
let baseResult =
    block
        value : Int
        let value =
            42
        value

liftResult : Int -> Int
let liftResult value = value

result : Int
let result = liftResult baseResult

--! assertNoErrors
--! assertType result Int
--! assertExecute result 42
