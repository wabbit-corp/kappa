module main

-- Manual oracle seed: recursive algebraic data and pattern matching.
data Tree : Type =
    Leaf : Int -> Tree
    Branch : Tree -> Tree -> Tree

sumTree : Tree -> Int
let sumTree tree =
    match tree
      case Leaf value -> value
      case Branch left right -> sumTree left + sumTree right

baseResult : Int
let baseResult = sumTree (Branch (Leaf 10) (Branch (Leaf 20) (Leaf 12)))

result : Int
let result = if True then baseResult else 0

