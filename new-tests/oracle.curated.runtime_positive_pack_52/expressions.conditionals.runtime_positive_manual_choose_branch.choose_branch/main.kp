module main

-- Manual oracle seed: explicit conditional branch selection.
choose : Bool -> Int -> Int -> Int
let choose flag left right =
    if flag then left else right

baseResult : Int
let baseResult = choose True 42 0

chooseResult : Bool -> Int -> Int -> Int
let chooseResult flag left right =
    if flag then left else right

result : Int
let result = chooseResult True baseResult 0

