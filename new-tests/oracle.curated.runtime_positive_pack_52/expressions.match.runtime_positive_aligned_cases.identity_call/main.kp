module main

sumList : List Int -> Int
let sumList xs =
    match xs
    case Nil -> 0
    case head :: tail -> head + sumList tail

baseResult : Int
let baseResult = sumList (10 :: 20 :: 42 :: Nil)

liftResult : Int -> Int
let liftResult value = value

result : Int
let result = liftResult baseResult

