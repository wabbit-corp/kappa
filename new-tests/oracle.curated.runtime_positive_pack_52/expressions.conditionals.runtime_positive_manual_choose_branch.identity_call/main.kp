module main

-- Manual oracle seed: explicit conditional branch selection.
choose : Bool -> Int -> Int -> Int
let choose flag left right =
    if flag then left else right

baseResult : Int
let baseResult = choose True 42 0

liftResult : Int -> Int
let liftResult value = value

result : Int
let result = liftResult baseResult

--! assertNoErrors
--! assertType result Int
--! assertExecute result 42
