module main

-- Source issue: Idris2#601
-- Kappa analogue: propositional equality on floating-point values follows raw-bit equality, so `-0.0` and `0.0`
-- are not definitionally equal and cannot be proven by `refl`.
-- Spec: §4.1.3, §4.1.4, §5.6.1
minusZero : Double
let minusZero = -0.0

plusZero : Double
let plusZero = 0.0

bad : minusZero = plusZero
let bad = refl

--! assertErrorCount 1
--! assertDiagnosticCodes E_TYPE_EQUALITY_MISMATCH
