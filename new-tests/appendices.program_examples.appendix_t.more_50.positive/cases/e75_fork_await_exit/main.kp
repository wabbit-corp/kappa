module cases.e75_fork_await_exit.main

main : UIO Unit
let main = do
    let fiber <- fork (pure 42)
    let exit <- await fiber
    match exit
    case Success n -> if n == 42 then println "await ok" else println "await bad"
    case Failure _ -> println "unexpected failure"

--! assertType cases.e75_fork_await_exit.main.main UIO Unit
