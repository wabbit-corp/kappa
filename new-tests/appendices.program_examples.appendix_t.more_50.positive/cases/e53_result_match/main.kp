module cases.e53_result_match.main

fromResult : Result String Int -> Int
let fromResult r =
    match r
    case Ok n -> n
    case Err _ -> 0

result : Int
let result = fromResult (Ok 42)

main : UIO Unit
let main = do
    let _ = result
    println "e53_result_match"

