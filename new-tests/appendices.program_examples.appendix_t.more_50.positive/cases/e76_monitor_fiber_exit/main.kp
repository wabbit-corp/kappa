module cases.e76_monitor_fiber_exit.main

main : UIO Unit
let main = do
    let fiber <- fork (pure 42)
    let mon <- monitor fiber
    let exit <- awaitMonitor mon
    demonitor mon
    match exit
    case Success n -> if n == 42 then println "monitor ok" else println "monitor bad"
    case Failure _ -> println "unexpected failure"

--! assertType cases.e76_monitor_fiber_exit.main.main UIO Unit
