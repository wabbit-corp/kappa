module cases.e52_option_elvis_nested_match.main

valueOr : Option Int -> Int
let valueOr opt =
    opt ?: 0

nested : Option (Option Int) -> Int
let nested opt =
    match opt
    case Some inner -> valueOr inner
    case None -> 0

result : Int
let result = nested (Some (Some 42))

main : UIO Unit
let main = do
    let _ = result
    println "e52_option_elvis_nested_match"

--! assertType cases.e52_option_elvis_nested_match.main.valueOr Option Int -> Int
--! assertType cases.e52_option_elvis_nested_match.main.nested Option (Option Int) -> Int
--! assertType cases.e52_option_elvis_nested_match.main.result Int
--! assertType cases.e52_option_elvis_nested_match.main.main UIO Unit
