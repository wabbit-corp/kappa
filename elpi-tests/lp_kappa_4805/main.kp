module main

generatedResize : (image : Int) -> (width : Int) -> (height : Int) -> Int
let generatedResize image width height = image + width * 10 + height

generated_4805 : Int
let generated_4805 = generatedResize { image = (((\(n : Int) -> n) ((Some (0 + 1)) ?: (0 + 2))) + 0), height = 3, width = 2 }

result : Int
let result = generated_4805

