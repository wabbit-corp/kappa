module main

type GeneratedUnit = Unit

type GeneratedPair = (left : Int, right : Int)

type GeneratedTuple = (Int, Int)

data GeneratedChoice : Type =
    GeneratedLeft (value : Int)
    GeneratedRight

trait GeneratedScore a =
    score : a -> Int

instance GeneratedScore Int =
    let score x = x

generatedResize : (image : Int) -> (width : Int) -> (height : Int) -> Int
let generatedResize image width height = image + width * 10 + height

generatedMakeConst : forall (a : Type). a -> Unit -> a
let generatedMakeConst value = \() -> value

generatedNeed : (@x : Int) -> Int
let generatedNeed (@x : Int) = x

generatedEcho : forall (a : Type). (this x : a) -> a
let generatedEcho @a (this x : a) = x

generatedSize : List Int -> Int
let generatedSize xs decreases structural xs =
    match xs
    case Nil -> 0
    case _ :: tail -> 1 + generatedSize tail

generated_70 : Int
let generated_70 =
    match 0x100
      case 0x100 -> 42
      case 0o100 -> 43
      case _ -> 0

result : Int
let result = generated_70

