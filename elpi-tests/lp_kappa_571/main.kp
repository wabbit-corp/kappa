    block
        scoped effect State (s : Type) =
            get : Unit -> s

        let seed = ((Some (0 + 1)) ?: (0 + 2))

        let comp : Eff <[State : State Int]> Int =
            do
                let n <- State.get ()
                n

        let handled : Eff <[ ]> Int =
            deep handle State comp with
                case return x -> pure x
                case get () k -> k seed

        runPure handled

result : Int
