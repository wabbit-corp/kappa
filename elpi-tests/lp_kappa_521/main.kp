module main

generated_521 : Int
let generated_521 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let pkg = (label = Ask)

        let seed = (match (0 == 0)
          case True -> 0
          case False -> 0)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- pkg.label.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle pkg.label comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_521

--! assertNoErrors
--! assertType generated_521 Int
--! assertType result Int
--! assertDeclKinds signature, let, signature, let
