module main

generatedResize : (image : Int) -> (width : Int) -> (height : Int) -> Int
let generatedResize image width height = image + width * 10 + height

generated_485 : Int
let generated_485 = generatedResize { image = ((match (0 == 0)
  case True -> 0
  case False -> 0) + 0), height = 3, width = 2 }

result : Int
let result = generated_485

