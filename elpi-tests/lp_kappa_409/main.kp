module main

generated_409 : Int
let generated_409 =
    block
        scoped effect State (s : Type) =
            get : Unit -> s

        let seed = (block
            let pair = (x = 0, y = (0 + 1))
            let (x = captured, y = other) = pair

            (captured + other))

        let comp : Eff <[State : State Int]> Int =
            do
                let n <- State.get ()
                n

        let handled : Eff <[ ]> Int =
            deep handle State comp with
                case return x -> pure x
                case get () k -> k seed

        runPure handled

result : Int
let result = generated_409

