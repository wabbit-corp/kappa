module main

generated_951 : Int
let generated_951 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        scoped effect Other =
            other : Unit -> Int

        let seed = ((\(n : Int) -> n) (block
            generatedListLength : List Int -> Int
            let generatedListLength xs decreases structural xs =
                match xs
                  case Nil -> 0
                  case _ :: tail -> 1 + generatedListLength tail

            let item = 0

            generatedListLength [item, (item + 1), 0]))

        let comp : Eff <[Ask : Ask, Other : Other]> Int =
            do
                let b <- Ask.ask ()
                let n <- Other.other ()
                if b then (n + seed) else seed

        let askHandled : Eff <[Other : Other]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        let handled : Eff <[ ]> Int =
            deep handle Other askHandled with
                case return x -> pure x
                case other () k -> k 1

        runPure handled

result : Int
let result = generated_951

