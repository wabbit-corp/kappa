module main

generated_4242 : Int
let generated_4242 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let seed = (match [(match (0 == 0)
          case True -> 0
          case False -> 0), ((match (0 == 0)
          case True -> 0
          case False -> 0) + 1)]
          case head :: tail -> head
          case Nil -> 0)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- Ask.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_4242

