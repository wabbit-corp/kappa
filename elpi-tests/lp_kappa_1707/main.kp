    block
        scoped effect Ask =
            ask : Unit -> Bool

        scoped effect Other =
            other : Unit -> Int

        let seed = (block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = (block
                generatedMapCount : Map String Int -> Int
                let generatedMapCount values = 1

                let item = 0
                let values = { yield "item" : item }

