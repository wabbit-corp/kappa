module main

generatedNeed : (@x : Int) -> Int
let generatedNeed (@x : Int) = x

generated_3232 : Int
let generated_3232 =
    block
        let (@x : Int) = (match [(block
            let pair = (x = 0, y = (0 + 1))
            let (x = captured, y = other) = pair

            (captured + other)), ((block
            let pair = (x = 0, y = (0 + 1))
            let (x = captured, y = other) = pair

            (captured + other)) + 1)]
          case head :: tail -> head
          case Nil -> 0)

        if True then generatedNeed else 0

result : Int
let result = generated_3232

