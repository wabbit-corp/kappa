module main

generated_2141 : Int
let generated_2141 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let pkg = (label = Ask)

        let seed = (block
            generatedSetCount : Set Int -> Int
            let generatedSetCount values = 2

            let item = (match (Some 0)
              case Some payload -> payload
              case None -> 0)
            let values = {|item, (item + 1)|}

            generatedSetCount values)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- pkg.label.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle pkg.label comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_2141

