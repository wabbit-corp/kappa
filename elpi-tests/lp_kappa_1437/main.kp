module main

generated_1437 : Int
let generated_1437 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        scoped effect Other =
            other : Unit -> Int

        let seed = ((\(n : Int) -> n) (block
            generatedSetCount : Set Int -> Int
            let generatedSetCount values = 2

            let item = 0
            let values = {|item, (item + 1)|}

            generatedSetCount values))

        let comp : Eff <[Ask : Ask, Other : Other]> Int =
            do
                let b <- Ask.ask ()
                let n <- Other.other ()
                if b then (n + seed) else seed

        let askHandled : Eff <[Other : Other]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        let handled : Eff <[ ]> Int =
            deep handle Other askHandled with
                case return x -> pure x
                case other () k -> k 1

        runPure handled

result : Int
let result = generated_1437

