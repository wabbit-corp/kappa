    block
        rankedHelper : (Int -> Int)
        let rankedHelper x = x + 1

        rankedHelper ((block
            let pair = (x = 0, y = (0 + 1))
            let (x = captured, y = other) = pair

            (captured + other)) + 0)

result : Int
let result = generated_381

