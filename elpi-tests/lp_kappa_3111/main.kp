module main

generated_3111 : Int
let generated_3111 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        scoped effect Other =
            other : Unit -> Int

        let seed = (block
            generatedSetCount : Set Int -> Int
            let generatedSetCount values = 2

            let item = (block
                let pair = (x = 0, y = (0 + 1))
                let (x = captured, y = other) = pair

                (captured + other))
            let values = {|item, (item + 1)|}

            generatedSetCount values)

        let comp : Eff <[Ask : Ask, Other : Other]> Int =
            do
                let b <- Ask.ask ()
                let n <- Other.other ()
                if b then (n + seed) else seed

        let askHandled : Eff <[Other : Other]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        let handled : Eff <[ ]> Int =
            deep handle Other askHandled with
                case return x -> pure x
                case other () k -> k 1

        runPure handled

result : Int
let result = generated_3111

