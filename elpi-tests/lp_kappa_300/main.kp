module main

generated_300 : Int
let generated_300 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let seed = (match (Some 0)
          case Some payload -> payload
          case None -> 0)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- Ask.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_300

--! assertNoErrors
--! assertType generated_300 Int
--! assertType result Int
--! assertDeclKinds signature, let, signature, let
