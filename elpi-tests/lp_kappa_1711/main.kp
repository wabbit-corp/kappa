module main

generated_1711 : Int
let generated_1711 =
    block
        scoped effect Choice =
            ω choose : Unit -> Bool

        let c = Choice

        let seed = (block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = (block
                generatedMapCount : Map String Int -> Int
                let generatedMapCount values = 1

                let item = 0
                let values = { yield "item" : item }

                generatedMapCount values)
            let values = { yield "item" : item }

            generatedMapCount values)

        let comp : Eff <[Choice : Choice]> Int =
            do
                let b <- c.choose ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Choice comp with
                case return x -> pure x
                case choose () k ->
                    do
                        let a <- k True
                        let b <- k False
                        pure (a + b)

        runPure handled

result : Int
let result = generated_1711

