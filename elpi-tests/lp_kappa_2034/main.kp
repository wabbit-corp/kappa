module main

generated_2034 : Int
let generated_2034 =
    block
        scoped effect Choice =
            ω choose : Unit -> Bool

        let seed = ((Some ((block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = 0
            let values = { yield "item" : item }

            generatedMapCount values) + 1)) ?: ((block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = 0
            let values = { yield "item" : item }

            generatedMapCount values) + 2))

        let comp : Eff <[Choice : Choice]> Int =
            do
