    block
        scoped effect Choice =
            ω choose : Unit -> Bool

        let c = Choice

        let seed = ((Some ((match [0, (0 + 1)]
          case head :: tail -> head
          case Nil -> 0) + 1)) ?: ((match [0, (0 + 1)]
