    block
        scoped effect Ask =
            ask : Unit -> Bool

        let seed = (match ((block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = 0
            let values = { yield "item" : item }

            generatedMapCount values) == (block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = 0
            let values = { yield "item" : item }

            generatedMapCount values))
          case True -> (block
              generatedMapCount : Map String Int -> Int
              let generatedMapCount values = 1

              let item = 0
              let values = { yield "item" : item }

              generatedMapCount values)
          case False -> 0)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- Ask.ask ()
                if b then seed else (seed + 1)

        let rehandle : (1 k : ((1 x : Bool) -> Eff <[Ask : Ask]> Int)) -> Eff <[ ]> Int =
            \(1 k : ((1 x : Bool) -> Eff <[Ask : Ask]> Int)) ->
                handle Ask (k True) with
                    case return y -> pure y
                    case ask () k2 -> k2 False

        let handled : Eff <[ ]> Int =
            handle Ask comp with
