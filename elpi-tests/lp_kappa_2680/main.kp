module main

generated_2680 : Int
let generated_2680 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let l = Ask

        let seed = (block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = (match [0, (0 + 1)]
              case head :: tail -> head
              case Nil -> 0)
            let values = { yield "item" : item }

            generatedMapCount values)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- l.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle l comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_2680

