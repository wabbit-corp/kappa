module main

generated_952 : Int
let generated_952 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let l = Ask

        let seed = ((\(n : Int) -> n) (block
            generatedListLength : List Int -> Int
            let generatedListLength xs decreases structural xs =
                match xs
                  case Nil -> 0
                  case _ :: tail -> 1 + generatedListLength tail

            let item = 0

            generatedListLength [item, (item + 1), 0]))

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- l.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle l comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_952

