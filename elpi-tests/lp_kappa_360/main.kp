module main

generated_360 : Int
let generated_360 =
    block
        scoped effect Choice =
            ω choose : Unit -> Bool

        let seed = (match [0, (0 + 1)]
          case head :: tail -> head
          case Nil -> 0)

        let comp : Eff <[Choice : Choice]> Int =
            do
                let b <- Choice.choose ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Choice comp with
                case return x -> pure x
                case choose () k ->
                    do
                        let a <- k True
                        let b <- k False
                        pure (a + b)

        runPure handled

result : Int
let result = generated_360

--! assertNoErrors
--! assertType generated_360 Int
--! assertType result Int
--! assertDeclKinds signature, let, signature, let
