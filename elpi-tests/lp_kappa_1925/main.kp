module main

generated_1925 : Int
let generated_1925 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let pkg = (label = Ask)

        let seed = ((\(n : Int) -> n) (block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = 0
            let values = { yield "item" : item }

            generatedMapCount values))

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- pkg.label.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle pkg.label comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_1925

