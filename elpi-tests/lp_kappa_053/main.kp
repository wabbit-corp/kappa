module main

generatedResize : (image : Int) -> (width : Int) -> (height : Int) -> Int
let generatedResize image width height = image + width * 10 + height

generated_53 : Int
let generated_53 = generatedResize { image = (0 + 0), height = 3, width = 2 }

result : Int
let result = generated_53

