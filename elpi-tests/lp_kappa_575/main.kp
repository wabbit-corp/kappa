module main

generated_575 : Int
let generated_575 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let pkg = (label = Ask)

        let seed = ((Some (0 + 1)) ?: (0 + 2))

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- pkg.label.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle pkg.label comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_575

