module main

generated_517 : Int
let generated_517 =
    block
        scoped effect State (s : Type) =
            get : Unit -> s

        let seed = (match (0 == 0)
          case True -> 0
          case False -> 0)

        let comp : Eff <[State : State Int]> Int =
            do
                let n <- State.get ()
                n

        let handled : Eff <[ ]> Int =
            deep handle State comp with
                case return x -> pure x
                case get () k -> k seed

        runPure handled

result : Int
let result = generated_517

