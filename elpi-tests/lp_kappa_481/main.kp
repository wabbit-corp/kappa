module main

trait GeneratedScore a =
    score : a -> Int

instance GeneratedScore Int =
    let score x = x

generated_481 : Int
let generated_481 =
    let
        dict = summon (GeneratedScore Int)
in
        dict.score ((match (0 == 0)
          case True -> 0
          case False -> 0) + 0)

result : Int
let result = generated_481

