module main

generatedEcho : forall (a : Type). (this x : a) -> a
let generatedEcho @a (this x : a) = x

generated_2048 : Int
let generated_2048 = ((block
    generatedListLength : List Int -> Int
    let generatedListLength xs decreases structural xs =
        match xs
          case Nil -> 0
          case _ :: tail -> 1 + generatedListLength tail

    let item = (match (Some 0)
      case Some payload -> payload
      case None -> 0)

    generatedListLength [item, (item + 1), 0]) + 0).generatedEcho

result : Int
let result = generated_2048

