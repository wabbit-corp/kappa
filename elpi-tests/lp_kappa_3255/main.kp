module main

data GeneratedChoice : Type =
    GeneratedLeft (value : Int)
    GeneratedRight

generated_3255 : Int
let generated_3255 =
    match GeneratedRight
      case GeneratedLeft payload -> (payload + 0)
      case GeneratedRight -> ((match [(block
          let pair = (x = 0, y = (0 + 1))
          let (x = captured, y = other) = pair

          (captured + other)), ((block
          let pair = (x = 0, y = (0 + 1))
          let (x = captured, y = other) = pair

          (captured + other)) + 1)]
        case head :: tail -> head
        case Nil -> 0) + 0)

result : Int
let result = generated_3255

