module main

trait GeneratedScore a =
    score : a -> Int

instance GeneratedScore Int =
    let score x = x

generated_265 : Int
let generated_265 =
    let
        dict = summon (GeneratedScore Int)
in
        dict.score ((match (Some 0)
          case Some payload -> payload
          case None -> 0) + 0)

result : Int
let result = generated_265

