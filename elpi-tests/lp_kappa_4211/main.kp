module main

generatedResize : (image : Int) -> (width : Int) -> (height : Int) -> Int
let generatedResize image width height = image + width * 10 + height

generated_4211 : Int
let generated_4211 = generatedResize { image = ((match [(match (0 == 0)
  case True -> 0
  case False -> 0), ((match (0 == 0)
  case True -> 0
  case False -> 0) + 1)]
  case head :: tail -> head
  case Nil -> 0) + 0), height = 3, width = 2 }

result : Int
let result = generated_4211

