module main

generated_88 : Int
let generated_88 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let l = Ask

        let seed = 0

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- l.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle l comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_88

