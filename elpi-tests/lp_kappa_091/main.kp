module main

generated_91 : Int
let generated_91 =
    block
        scoped effect Choice =
            ω choose : Unit -> Bool

        let c = Choice

        let seed = 0

        let comp : Eff <[Choice : Choice]> Int =
            do
                let b <- c.choose ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Choice comp with
                case return x -> pure x
                case choose () k ->
                    do
                        let a <- k True
                        let b <- k False
                        pure (a + b)

        runPure handled

result : Int
let result = generated_91

