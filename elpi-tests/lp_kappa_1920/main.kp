module main

generated_1920 : Int
let generated_1920 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let seed = ((\(n : Int) -> n) (block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = 0
            let values = { yield "item" : item }

            generatedMapCount values))

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- Ask.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_1920

--! assertNoErrors
--! assertType generated_1920 Int
