module main

generated_304 : Int
let generated_304 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let l = Ask

        let seed = (match (Some 0)
          case Some payload -> payload
          case None -> 0)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- l.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle l comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_304

--! assertNoErrors
--! assertType generated_304 Int
--! assertType result Int
