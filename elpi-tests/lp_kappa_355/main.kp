module main

generated_355 : Int
let generated_355 =
    block
        scoped effect State (s : Type) =
            get : Unit -> s

        let seed = (match [0, (0 + 1)]
          case head :: tail -> head
          case Nil -> 0)

        let comp : Eff <[State : State Int]> Int =
            do
                let n <- State.get ()
                n

        let handled : Eff <[ ]> Int =
            deep handle State comp with
                case return x -> pure x
                case get () k -> k seed

        runPure handled

result : Int
let result = generated_355

