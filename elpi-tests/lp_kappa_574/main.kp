module main

generated_574 : Int
let generated_574 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let l = Ask

        let seed = ((Some (0 + 1)) ?: (0 + 2))

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- l.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle l comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_574

