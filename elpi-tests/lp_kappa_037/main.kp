module main

generatedSize : List Int -> Int
let generatedSize xs decreases structural xs =
    match xs
    case Nil -> 0
    case _ :: tail -> 1 + generatedSize tail

generated_37 : Int
let generated_37 = generatedSize (1 :: 2 :: 3 :: Nil)

result : Int
let result = generated_37

