module main

generated_89 : Int
let generated_89 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let pkg = (label = Ask)

        let seed = 0

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- pkg.label.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle pkg.label comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_89

--! assertNoErrors
--! assertType generated_89 Int
