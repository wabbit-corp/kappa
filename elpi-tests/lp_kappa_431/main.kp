module main

generatedResize : (image : Int) -> (width : Int) -> (height : Int) -> Int
let generatedResize image width height = image + width * 10 + height

generated_431 : Int
let generated_431 = generatedResize { image = (((\(n : Int) -> n) 0) + 0), height = 3, width = 2 }

result : Int
let result = generated_431

