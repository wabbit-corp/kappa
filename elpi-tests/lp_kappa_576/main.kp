module main

generated_576 : Int
let generated_576 =
    block
        scoped effect Choice =
            ω choose : Unit -> Bool

        let seed = ((Some (0 + 1)) ?: (0 + 2))

        let comp : Eff <[Choice : Choice]> Int =
            do
                let b <- Choice.choose ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Choice comp with
                case return x -> pure x
                case choose () k ->
                    do
                        let a <- k True
                        let b <- k False
                        pure (a + b)

        runPure handled

result : Int
let result = generated_576

--! assertNoErrors
--! assertType generated_576 Int
