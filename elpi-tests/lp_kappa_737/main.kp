module main

generated_737 : Int
let generated_737 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let pkg = (label = Ask)

        let seed = (block
            generatedMapCount : Map String Int -> Int
            let generatedMapCount values = 1

            let item = (block
                generatedListLength : List Int -> Int
                let generatedListLength xs decreases structural xs =
                    match xs
                      case Nil -> 0
                      case _ :: tail -> 1 + generatedListLength tail

                let item = 0

                generatedListLength [item, (item + 1), 0])
            let values = { yield "item" : item }

            generatedMapCount values)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- pkg.label.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle pkg.label comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_737

