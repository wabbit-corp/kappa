module main

generated_678 : Int
let generated_678 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let seed = (block
            generatedSetCount : Set Int -> Int
            let generatedSetCount values = 2

            let item = (block
                generatedListLength : List Int -> Int
                let generatedListLength xs decreases structural xs =
                    match xs
                      case Nil -> 0
                      case _ :: tail -> 1 + generatedListLength tail

                let item = 0

                generatedListLength [item, (item + 1), 0])
            let values = {|item, (item + 1)|}

            generatedSetCount values)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- Ask.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_678

