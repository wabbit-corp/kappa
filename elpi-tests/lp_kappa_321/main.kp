module main

data GeneratedChoice : Type =
    GeneratedLeft (value : Int)
    GeneratedRight

generated_321 : Int
let generated_321 =
    match (GeneratedLeft ((match [0, (0 + 1)]
      case head :: tail -> head
      case Nil -> 0) + 0))
      case GeneratedLeft payload -> (payload + 0)
      case GeneratedRight -> ((match [0, (0 + 1)]
        case head :: tail -> head
        case Nil -> 0) + 0)

result : Int
let result = generated_321

