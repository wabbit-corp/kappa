module main

data GeneratedChoice : Type =
    GeneratedLeft (value : Int)
    GeneratedRight

generated_285 : Int
let generated_285 =
    match GeneratedRight
      case GeneratedLeft payload -> (payload + 0)
      case GeneratedRight -> ((match (Some 0)
        case Some payload -> payload
        case None -> 0) + 0)

result : Int
let result = generated_285

