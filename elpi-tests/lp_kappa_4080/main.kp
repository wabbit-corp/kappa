module main

generated_4080 : Int
let generated_4080 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let seed = (block
            generatedSetCount : Set Int -> Int
            let generatedSetCount values = 2

            let item = (match (0 == 0)
              case True -> 0
              case False -> 0)
            let values = {|item, (item + 1)|}

            generatedSetCount values)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- Ask.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_4080

