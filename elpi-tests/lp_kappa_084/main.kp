module main

generated_84 : Int
let generated_84 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let seed = 0

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- Ask.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle Ask comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_84

