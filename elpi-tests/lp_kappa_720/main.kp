module main

generatedNeed : (@x : Int) -> Int
let generatedNeed (@x : Int) = x

generated_720 : Int
let generated_720 = generatedNeed @(((block
    generatedMapCount : Map String Int -> Int
    let generatedMapCount values = 1

    let item = (block
        generatedListLength : List Int -> Int
        let generatedListLength xs decreases structural xs =
            match xs
              case Nil -> 0
              case _ :: tail -> 1 + generatedListLength tail

        let item = 0

        generatedListLength [item, (item + 1), 0])
    let values = { yield "item" : item }

    generatedMapCount values) + 0))

result : Int
let result = generated_720

