module main

data GeneratedChoice : Type =
    GeneratedLeft (value : Int)
    GeneratedRight

generated_11 : (GeneratedChoice -> Int)
let generated_11 = \(choice : GeneratedChoice) ->
    match choice
      case GeneratedLeft payload -> payload
      case GeneratedRight -> 0

result : (GeneratedChoice -> Int)
let result = generated_11

