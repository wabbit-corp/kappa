module main

generated_520 : Int
let generated_520 =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let l = Ask

        let seed = (match (0 == 0)
          case True -> 0
          case False -> 0)

        let comp : Eff <[Ask : Ask]> Int =
            do
                let b <- l.ask ()
                if b then seed else (seed + 1)

        let handled : Eff <[ ]> Int =
            deep handle l comp with
                case return x -> pure x
                case ask () k -> k True

        runPure handled

result : Int
let result = generated_520

--! assertNoErrors
--! assertType generated_520 Int
--! assertType result Int
--! assertDeclKinds signature, let, signature, let
