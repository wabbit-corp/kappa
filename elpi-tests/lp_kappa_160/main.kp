module main

type GeneratedPair = (left : Int, right : Int)

generated_160 : GeneratedPair
let generated_160 = ((left = (block
    generatedSetCount : Set Int -> Int
    let generatedSetCount values = 2

    let item = 0
    let values = {|item, (item + 1)|}

    generatedSetCount values), right = 0)).{ right = ((block
    generatedSetCount : Set Int -> Int
    let generatedSetCount values = 2

    let item = 0
    let values = {|item, (item + 1)|}

    generatedSetCount values) + 1) }

result : GeneratedPair
let result = generated_160

--! assertNoErrors
--! assertType generated_160 GeneratedPair
--! assertType result GeneratedPair
--! assertDeclKinds type, signature, let, signature, let
