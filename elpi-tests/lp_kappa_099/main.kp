module main

type GeneratedUnit = Unit

type GeneratedPair = (left : Int, right : Int)

type GeneratedTuple = (Int, Int)

data GeneratedChoice : Type =
    GeneratedLeft (value : Int)
    GeneratedRight

trait GeneratedScore a =
    score : a -> Int

instance GeneratedScore Int =
    let score x = x

generated_99 : (GeneratedChoice -> Int)
let generated_99 = \(choice : GeneratedChoice) ->
    match choice
      case GeneratedLeft payload -> payload
      case GeneratedRight -> 0

result : (GeneratedChoice -> Int)
let result = generated_99

