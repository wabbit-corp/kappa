@PrivateByDefault module showcase.effects

askTwice : (1 x : Int) -> Int
let askTwice (1 x : Int) : Int =
    block
        scoped effect Ask =
            ask : Unit -> Bool

        let comp : Eff <[Ask : Ask]> Int =
            do
                keep <- Ask.ask ()
                if keep then x else x

        let handled =
            deep handle Ask comp with
                case return y -> pure y
                case ask _ k -> k True

        runPure handled
