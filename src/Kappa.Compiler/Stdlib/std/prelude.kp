module std.prelude

infix 50 (==)
infix 40 (~=)
infix 40 (/=)
infix 40 (!=)
infix 40 (<)
infix 40 (<=)
infix 40 (>)
infix 40 (>=)
infix 45 (..)
infix 45 (..<)
infix right 50 (::)
prefix 80 (-)
infix left 60 (+)
infix left 60 (-)
infix left 70 (*)
infix left 70 (/)
infix right 30 (&&)
infix right 20 (||)
infix left 10 (>>=)
infix right 20 (<|>)
infix left 1 (|>)
infix right 0 (<|)

data Void : Type

data Unit : Type =
    Unit

data Bool : Type =
    True
    False

data Option a : Type =
    None
    Some a

data Result e a : Type =
    Ok a
    Err e

data List a : Type =
    Nil
    (::) (head : a) (tail : List a)

data Ordering : Type =
    LT
    EQ
    GT

data Res (a : Type) (r : Type) : Type =
    (:&) (value : a) (resource : r)

data Match (a : Type) (r : Type) : Type =
    Hit a
    Miss r

data Dec (p : Type) : Type =
    Yes p
    No

data SyntaxFragment : Type =
    Lit String
    Interp (@t : Type) (Syntax t)
    InterpFmt (@t : Type) (Syntax t) String

data InterruptTag : Type =
    Requested
    ScopeShutdown
    TimedOut
    RaceLost
    External
    Custom

data InterruptCause : Type =
    InterruptCause InterruptTag

data DefectTag : Type =
    Panic
    AssertionFailed
    ArithmeticFault
    StackOverflow
    OutOfMemory
    HostFailure
    ForeignContractViolation
    UnhandledChildFailure
    OtherDefect

data DefectInfo : Type =
    DefectInfo DefectTag String

data Cause (e : Type) : Type =
    Fail e
    Interrupt InterruptCause
    Defect DefectInfo
    Both (Cause e) (Cause e)
    Then (Cause e) (Cause e)

data Exit (e : Type) (a : Type) : Type =
    Success a
    Failure (Cause e)

data TimeoutError : Type =
    Timeout

data RaceResult (a : Type) (b : Type) : Type =
    LeftWins a
    RightWins b

data (=) (a : Type) (x : a) : a -> Type =
    refl

expect type UnicodeScalar
expect type Grapheme
expect type Byte
type Char = UnicodeScalar
expect type String
expect type Int
expect type Nat
expect type Integer
expect type Double
expect type Real
type Float = Double
expect type Bytes
expect type Array (a : Type)
expect type Ref (a : Type)
