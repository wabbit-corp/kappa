module main

--! allow_unsafe_consume

data File : Type =
    Handle Int

let consume (1 file : File) = unsafeConsume file

let main : IO Unit = do
    let & file = Handle 1
    consume file

--! assertErrorCount 1
--! assertDiagnosticCodes E_QTT_BORROW_CONSUME
--! assertDiagnosticAt main.kp error E_QTT_BORROW_CONSUME 12
