module service.reporting

import model.data.*
import dsl.sql.*

topCustomerQuery : SqlQuery (id : Int, name : String, orders : List Order)
let topCustomerQuery =
    SqlQuery [
        for u in users
        join o in orders on o.userId == u.id
        if o.status == "paid"
        group by u.id {
            orders = [o]
        } into g
        order by g.key
        yield (id = g.key, name = "customer", orders = g.orders)
    ]

preparedAudit : Int -> PreparedSql Order
let preparedAudit orderId =
    sql"select * from orders where id = ${orderId : param}"
