module main

--! allow_unsafe_consume

data File : Type =
    Handle Int

let h (1 left : File) (1 right : File) =
    let _ = unsafeConsume left
    in let _ = unsafeConsume right in ()

let main : IO Unit = do
    let 1 file = Handle 1
    h file file

--! assertErrorCount 1
--! assertDiagnosticCodes E_QTT_LINEAR_OVERUSE
--! assertDiagnosticAt main.kp error E_QTT_LINEAR_OVERUSE 14
