module main

data Token : Type =
    Token

consumeToken : (1 t : Token) -> Int
let consumeToken t =
    match t
    case Token -> 1

keyOfToken : (& t : Token) -> Int
let keyOfToken t = 0

fromOneShot : (1 src : QueryCore (QueryMode.QueryMode QueryUse.OneShot QueryCard.QZeroOrMore) 1 Token) -> OnceQuery Int
let fromOneShot src =
    OnceQuery [
        for t in src
        yield consumeToken t
    ]

--! assertNoErrors
--! assertType fromOneShot (1 src : QueryCore (QueryMode.QueryMode QueryUse.OneShot QueryCard.QZeroOrMore) 1 Token) -> OnceQuery Int
