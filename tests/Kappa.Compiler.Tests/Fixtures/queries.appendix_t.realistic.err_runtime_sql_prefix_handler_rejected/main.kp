module main

import model.data.*
import dsl.sql.*

summonDict : (c : Constraint) -> (@v : c) -> Dict c
let summonDict c @v = v

runtimeSql : Dict (InterpolatedMacro (PreparedSql User))
let runtimeSql =
    summonDict (InterpolatedMacro (PreparedSql User))

bad : PreparedSql User
let bad =
    runtimeSql"select * from users where id = ${1 : param}"
