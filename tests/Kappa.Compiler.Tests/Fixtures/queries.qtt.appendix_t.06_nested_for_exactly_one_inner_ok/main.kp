module main

data Token : Type =
    Token

consumeToken : (1 t : Token) -> Int
let consumeToken t =
    match t
    case Token -> 1

keyOfToken : (& t : Token) -> Int
let keyOfToken t = 0

ok :
    (1 xs : QueryCore (QueryMode.QueryMode QueryUse.OneShot QueryCard.QZeroOrMore) 1 Token) ->
    (ys : QueryCore (QueryMode.QueryMode QueryUse.Reusable QueryCard.QOne) ω Int) ->
    OnceQuery Int
let ok xs ys =
    OnceQuery [
        for t in xs
        for y in ys
        yield consumeToken t + y
    ]

--! assertNoErrors
