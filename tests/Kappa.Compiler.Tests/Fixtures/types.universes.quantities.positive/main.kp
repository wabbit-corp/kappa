module main

data File : Type =
    Handle Int

let consume (1 f : File) = ()
let borrow (& f : File) = ()
let borrowScoped (&[s] f : File) = ()
let erase (0 proof : Unit) = ()
let share (ω x : Int) = x
let maybe (<=1 x : Int) = x
let atLeast (>=1 x : Int) = x

