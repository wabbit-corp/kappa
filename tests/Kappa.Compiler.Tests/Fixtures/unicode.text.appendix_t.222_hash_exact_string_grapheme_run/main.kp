module main
import std.hash.*
import std.unicode.*

check : Bool -> String -> String -> UIO Unit
let check cond ok fail =
    if cond then printlnString ok else printlnString fail

main : UIO Unit
let main =
    do
        check (hashWith defaultHashSeed "\u{00E9}" == hashWith defaultHashSeed "\u{00E9}") "hash-string-exact-ok" "hash-string-exact-fail"
        check (hashWith defaultHashSeed g'e\u{301}' == hashWith defaultHashSeed g'e\u{301}') "hash-grapheme-exact-ok" "hash-grapheme-exact-fail"
        check (hashWith defaultHashSeed (normalize NFC "\u{00E9}") == hashWith defaultHashSeed (normalize NFC "e\u{301}")) "hash-normalized-strings-ok" "hash-normalized-strings-fail"
