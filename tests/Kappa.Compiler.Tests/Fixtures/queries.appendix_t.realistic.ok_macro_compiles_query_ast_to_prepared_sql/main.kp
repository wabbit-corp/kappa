module main

import model.data.*
import dsl.sql.*

compileQueryText : Syntax (SqlQuery row) -> Elab (Syntax (PreparedSql row))
let compileQueryText queryAst =
    do
        let _rendered <- renderSyntax queryAst
        pure '{ PreparedSql "prepared-from-query-ast" }

preparedTopCustomers : PreparedSql (id : Int, name : String)
let preparedTopCustomers =
    $(compileQueryText '{
        SqlQuery [
            for u in users
            join o in orders on o.userId == u.id
            if o.status == "paid"
            distinct by u.id
            order by u.name
            take 10
            yield (id = u.id, name = u.name)
        ]
    })
