module main

import model.data.*
import dsl.sql.*

bigRevenue : SqlQuery (region : String, orders : List Order)
let bigRevenue =
    SqlQuery [
        for u in users
        join o in orders on o.userId == u.id
        if u.region == "North"
        if o.total > 100
        group by u.region {
            orders = [o]
        } into g
        order by desc g.key
        take 10
        yield (region = g.key, orders = g.orders)
    ]
