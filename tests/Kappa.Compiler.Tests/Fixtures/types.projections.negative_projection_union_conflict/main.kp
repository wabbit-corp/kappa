module main

data Buffer : Type =
    Buffer

type Pair = (1 buf : Buffer)

consumeWhole : (1 p : Pair) -> Unit
let consumeWhole p = ()

projection chooseBuf (place a : Pair) (place b : Pair) (which : Bool) =
    if which then yield a.buf else yield b.buf

bad : (1 a : Pair) -> (1 b : Pair) -> Bool -> Unit
let bad a b which =
    let & p = chooseBuf a b which
    consumeWhole a

--! assertErrorCount 1
--! assertDiagnosticCodes E_PROJECTION_DEFINITION_UNSUPPORTED
