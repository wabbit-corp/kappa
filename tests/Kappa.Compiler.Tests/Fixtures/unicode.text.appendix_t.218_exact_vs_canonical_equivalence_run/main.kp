module main
import std.unicode.*

check : Bool -> String -> String -> UIO Unit
let check cond ok fail =
    if cond then printlnString ok else printlnString fail

main : UIO Unit
let main =
    do
        check (("\u{00E9}" == "e\u{301}") == False) "exact-eq-false-ok" "exact-eq-false-fail"
        check (canonicalEquivalent "\u{00E9}" "e\u{301}") "canonical-equivalent-ok" "canonical-equivalent-fail"
        check (normalize NFC "\u{00E9}" == normalize NFC "e\u{301}") "nfc-eq-ok" "nfc-eq-fail"
        check (normalize NFD "\u{00E9}" == normalize NFD "e\u{301}") "nfd-eq-ok" "nfd-eq-fail"
