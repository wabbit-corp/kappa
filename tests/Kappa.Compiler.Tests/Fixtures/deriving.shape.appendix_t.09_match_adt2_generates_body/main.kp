module main

import support.shape_assert.(deriveSameConstructorBody)

data Expr : Type =
    Lit (value : Int)
    Add (left : Expr) (right : Expr)
    Var (name : String)

sameConstructor : Expr -> Expr -> Bool
let sameConstructor left right =
    $(deriveSameConstructorBody @Expr '{ Expr } '{ left } '{ right })

--! assertNoErrors
--! assertType sameConstructor Expr -> Expr -> Bool
--! assertDeclKinds import, data, signature, let
