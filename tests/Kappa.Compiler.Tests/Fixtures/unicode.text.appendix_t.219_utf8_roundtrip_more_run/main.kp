module main
import std.unicode.*

check : Bool -> String -> String -> UIO Unit
let check cond ok fail =
    if cond then printlnString ok else printlnString fail

isOkString : Result UnicodeDecodeError String -> String -> Bool
let isOkString result expected =
    match result
    case Ok s -> s == expected
    case Err _ -> False

main : UIO Unit
let main =
    do
        check (isOkString (decodeUtf8 (utf8Bytes "")) "") "decode-empty-ok" "decode-empty-fail"
        check (isOkString (decodeUtf8 (utf8Bytes "a")) "a") "decode-a-ok" "decode-a-fail"
        check (isOkString (decodeUtf8 (utf8Bytes "e\u{301}")) "e\u{301}") "decode-combining-ok" "decode-combining-fail"
        check (isOkString (decodeUtf8 (utf8Bytes "\u{1F1FA}\u{1F1F8}")) "\u{1F1FA}\u{1F1F8}") "decode-flag-ok" "decode-flag-fail"
        check (decodeUtf8Lossy (utf8Bytes "\u{1F642}") == "\u{1F642}") "decode-lossy-valid-ok" "decode-lossy-valid-fail"
